# Local development configuration
# For deployment, these are set via Terraform / the deploy command.
# Copy to .env and fill in values. Do NOT commit .env (it is gitignored).

# =============================================================================
# Model backend / authentication
# =============================================================================

# --- Option A: Vertex AI (default) ---
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# --- Option B: Gemini API via Google AI Studio ---
# Comment out the three lines above and uncomment:
# GEMINI_API_KEY=your-api-key-here

# --- Option C: Anthropic (Claude) via LiteLLM ---
# Set REVIEW_MODEL to an anthropic/* id (see below) and provide:
# ANTHROPIC_API_KEY=your-api-key-here

# =============================================================================
# Model selection
# =============================================================================

# Which model runs the review. Bare "gemini-*" ids use ADK-native Gemini;
# "provider/model" ids (e.g. anthropic/claude-sonnet-5) route through LiteLLM.
# Default: gemini-flash-latest
# REVIEW_MODEL=gemini-flash-latest
# REVIEW_MODEL=anthropic/claude-sonnet-5

# =============================================================================
# Data sources
# =============================================================================

# Email sent to the OpenAlex API for the "polite pool" (fewer 503s / rate limits).
# OPENALEX_MAILTO=you@example.com

# =============================================================================
# Web serving (FastAPI)
# =============================================================================

# Comma-separated list of allowed CORS origins. Empty = none.
# ALLOW_ORIGINS=https://app.example.com,https://staging.example.com

# Public URL used to build the A2A agent card. Auto-derived if unset.
# APP_URL=https://your-service.example.com

# Agent card version reported by the A2A endpoint. Default: 0.1.0
# AGENT_VERSION=0.1.0

# =============================================================================
# Sessions & storage
# =============================================================================

# Backing store for agent sessions. Default: shared://session (in-memory).
# Use a database URI (e.g. postgresql://...) for persistence.
# SESSION_SERVICE_URI=shared://session

# Deployed Agent Engine instance to bind sessions/telemetry to.
# GOOGLE_CLOUD_AGENT_ENGINE_ID=
# GOOGLE_CLOUD_AGENT_ENGINE_LOCATION=us-east1

# =============================================================================
# Telemetry & observability (optional)
# =============================================================================

# GCS bucket for prompt/response logging. Setting this + capture mode enables it.
# LOGS_BUCKET_NAME=gs://your-bucket

# Send traces/logs to the Agent Engine (customer project). Default: true
# GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true

# Capture prompt/response content. "false" (default) disables; "NO_CONTENT"
# logs metadata only. Requires LOGS_BUCKET_NAME to take effect.
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false

# Keep full prompts/responses out of trace span attributes. Default: false
# ADK_CAPTURE_MESSAGE_CONTENT_IN_SPANS=false

# Subpath under the logs bucket for uploaded completions. Default: completions
# GENAI_TELEMETRY_PATH=completions

# Upload format / hook for GenAI completion logging (advanced; sane defaults).
# OTEL_INSTRUMENTATION_GENAI_UPLOAD_FORMAT=jsonl
# OTEL_INSTRUMENTATION_GENAI_COMPLETION_HOOK=upload

# Commit SHA stamped into the OTel service.version resource attribute. Default: dev
# COMMIT_SHA=dev
